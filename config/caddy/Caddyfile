:80 {
    # Citizens Service
    @citizen_match {
        path /api/v1/citizen /api/v1/citizen/*
    }

    handle @citizen_match {
        reverse_proxy tasks.citizen-query-service:8080
    }

    # Results Service
    @results_match {
        path /api/v1/results /api/v1/results/*
    }

    handle @results_match {
        reverse_proxy tasks.results-service:8080
    }

    # Elections Service
    @elections_match {
        path /api/v1/elections /api/v1/elections/*
    }
    
    handle @elections_match {
        reverse_proxy tasks.elections-query-service:8080
    }

    # Transparency Service
    @transparency_match {
        path /api/v1/transparency /api/v1/transparency/*
    }
    
    handle @transparency_match {
        reverse_proxy tasks.transparency-service:8080
    }

    handle /keycloak {
        reverse_proxy tasks.keycloak:8080
    }

    # Catch the rest of the calls to prevent
    # endpoint issues. - Augusto
    handle /api/* {
        respond "Forbidden" 403
    }

    # Frontend
    handle {
        reverse_proxy frontend:80
    }
}