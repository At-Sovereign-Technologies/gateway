:80 {
    # Citizens query
    @citizen_paths path /api/v1/citizen /api/v1/citizen/*
    handle @citizen_paths {
        reverse_proxy citizen-query-service:8080
    }

    # Results service
    @results_paths path /api/v1/results /api/v1/results/*
    handle @results_paths {
        reverse_proxy results-service:8080
    }

    # Elections Service
    @elections_paths path /api/v1/elections /api/v1/elections/*
    handle @elections_paths {
        reverse_proxy elections-query-service:8080
    }

    # Catch all for problems
    handle /api/* {
        respond "Forbidden" 403
    }

    # Frontend
    handle {
        reverse_proxy frontend:80
    }
}