:80 {
    # Citizens query
    @citizen_match {
        path /api/v1/citizen /api/v1/citizen/*
    }

    handle @citizen_match {
        reverse_proxy citizen-query-service:8080
    }

    # Results service
    @results_match {
        path /api/v1/results /api/v1/results/*
    }

    handle @results_match {
        reverse_proxy results-service:8080
    }

    # Elections Service
    @elections_match {
        path /api/v1/elections /api/v1/elections/*
    }
    
    handle @elections_match {
        reverse_proxy elections-query-service:8080
    }

    # Catch the rest of the calls to prevent
    # endpoint issues. - Augusto
    handle /api/* {
        respond "Forbidden" 403
    }

    # Frontend
    handle {
        reverse_proxy frontend:80
    }
}